---
import { Image } from 'astro:assets';
import heroImage from '@/assets/Hero.png';
---

<div id="home" class="relative min-h-screen w-full flex items-center justify-center overflow-hidden ">
  <div class="absolute inset-0 w-full h-full z-0">
    <Image
      src={heroImage}
      alt="Volleyball action"
      class="w-full h-full object-cover opacity-40 block"
    />
   </div>
  <div class="text-center z-10">
        <p class="text-lg  text-black/70 tracking-widest uppercase mb-2">
            ASSOCIAZIONE DI PALLAVOLO
        </p>
         <h1 class="text-5xl md:text-7xl font-bold tracking-widest uppercase  mb-4">
            Black Bulls
         </h1>
        <h1 class="text-5xl md:text-4xl font-bold tracking-widest uppercase  text-red-500">Volley</h1>
  </div>
</div>
