---
import {Image} from 'astro:assets';
import heroImage from '@/assets/Hero.png';
import React from "react";
---

<div id="home" class="relative min-h-screen w-full flex items-center justify-center overflow-hidden ">
    <div class="absolute inset-0 w-full h-full z-0">
        <Image
                src={heroImage}
                alt="Volleyball action"
                class="w-full h-full object-cover block"
        />
    </div>
    <div class="text-center z-10">
        <h1 class="mt-4 text-6xl md:text-8xl font-black text-white tracking-tighter leading-none">
            BLACK BULLS<br/>
            <span class="text-red-600">VOLLEY</span>
        </h1>
    </div>
</div>
